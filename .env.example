VIRUSTOTAL_API_KEY=your_virustotal_key_here
URLSCAN_API_KEY=your_urlscan_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_key_here

# Credenciales para proteger la app (HTTP Basic Auth).
# Si APP_PASSWORD está vacío, la app queda ABIERTA sin login (solo para uso local).
# Obligatorio definirlas antes de exponer la app en red o en Render.
APP_USERNAME=admin
APP_PASSWORD=
